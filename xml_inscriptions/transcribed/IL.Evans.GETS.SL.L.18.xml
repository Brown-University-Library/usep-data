                <lb n="2"/> in pace
                <lb n="3"/> <expan><abbr>q</abbr><ex>ui</ex></expan> <choice><reg>vixet</reg><orig>vixxet</orig></choice>
                <lb n="4"/> <choice><reg>annos</reg><orig>annus</orig></choice>
                <lb n="5"/> viginti
                <lb n="6"/> et qui<choice><corr>n</corr><sic>ii</sic></choice>que
                <lb n="7"/> et <expan><abbr>me</abbr><ex>nses</ex></expan> 
                <lb n="8" break="no"/> <choice><reg>quattuor</reg><orig>quadior</orig></choice>. <g type="star"/>
            </ab></div>
            
            <div type="translation">
            <p>Venerius, in peace, who lived 25 years and 4 months.</p></div>

